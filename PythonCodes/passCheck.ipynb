    "password = input(\"Enter your password: \")\n",
    "length = len(password)\n",
    "\n",
    "temp = \"\"\n",
    "for i in range(length):\n",
    "    temp += \"*\"\n",
    "    \n",
    "\n",
    "print(f\"Your password is: {temp} of length {length}\")"
