    "import numpy as np\n",
    "\n",
    "np.random.seed(0)  \n",
    "\n",
    "mat1 = np.random.randint(10, size=(3, 3))\n",
    "mat2 = np.random.randint(10, size=(3, 3))\n",
    "\n",
    "print(mat1 * mat2)\n",
    "\n",
    "print()\n",
    "\n",
    "print(np.dot(mat1, mat2))\n",
    "\n",
    "print()\n",
    "\n",
    "print(mat1.dot(mat2))\n",
    "\n",
    "print()\n",
    "\n",
    "print(mat1 @ mat2)"
   ]
  }
