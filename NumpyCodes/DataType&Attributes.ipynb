    "import numpy as np\n",
    "\n",
    "## Data Types and Attributes\n",
    "\n",
    "a1 = np.array([1, 2, 3])\n",
    "print(type(a1))\n",
    "\n",
    "a2 = np.array([[1, 2.0, 3], [5, 6, 7]])\n",
    "\n",
    "print(a1.shape, a2.shape)\n",
    "\n",
    "print(a1.ndim, a2.ndim)\n",
    "\n",
    "print(a1.dtype, a2.dtype)\n",
    "\n",
    "print(a1.size, a2.size)"
   ]
  }
