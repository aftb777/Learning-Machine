    "### *args ###\n",
    "\n",
    "def super_func(*args):\n",
    "    return sum(args)\n",
    "\n",
    "print(super_func(1, 2, 3, 4, 5))\n",
    "print()\n",
    "\n",
    "### **kwargs ###\n",
    "\n",
    "def Super_func(**kwargs):\n",
    "    total = 0\n",
    "    for key, value in kwargs.items():\n",
    "        total += value\n",
    "    return total\n",
    "\n",
    "print(Super_func(a=1, b=2, c=3, d=4, e=5))"
   ]
  }
